[env]
API_DEBUG = "1"
IMAGE_BASE_DIR = "."
LOG_LEVEL = "INFO"

# Async jobs
COMPARE_JOB_WORKERS = 2
QUEUE_MAXSIZE = 0

# Optional API logging sink
LOG_API_ENABLED = false
LOG_API_URL = ""
LOG_API_LEVEL = "ERROR"
LOG_API_TIMEOUT_MS = 2000
LOG_API_TOKEN = ""
LOG_SERVICE_NAME = "perceptual-metrics-service"

# Optional runtime git metadata overrides
APP_GIT_BRANCH = ""
APP_GIT_TAG = ""
APP_GIT_LAST_COMMIT = ""
APP_GIT_COMMITTER = ""
APP_GIT_COMMIT_DATE = ""
