[env]
API_DEBUG = "1"
IMAGE_BASE_DIR = "."
COMPARE_TMP_DIR = ".compare_tmp"
LOG_LEVEL = "INFO"

# API hardening
COMPARE_MAX_FILE_SIZE_BYTES = 10485760
COMPARE_MAX_TOTAL_UPLOAD_BYTES = 20971520
COMPARE_ALLOWED_IMAGE_FORMATS = "png,jpeg,webp"
COMPARE_MAX_IMAGE_SIDE = 8192
COMPARE_MAX_IMAGE_PIXELS = 40000000
COMPARE_RATE_LIMIT_ENABLED = false
COMPARE_RATE_LIMIT_CREATE_LIMIT = 60
COMPARE_RATE_LIMIT_CREATE_WINDOW_SEC = 60
COMPARE_RATE_LIMIT_READ_LIMIT = 240
COMPARE_RATE_LIMIT_READ_WINDOW_SEC = 60

# Distributed jobs (Celery + Redis)
JOB_STORE_BACKEND = "redis" # redis|memory
REDIS_URL = "redis://127.0.0.1:6379/0"
REDIS_PREFIX = "pms"
JOB_TTL_SEC = 86400
HEATMAP_TTL_SEC = 86400

CELERY_BROKER_URL = "redis://127.0.0.1:6379/0"
CELERY_RESULT_BACKEND = "redis://127.0.0.1:6379/0"
CELERY_TASK_ALWAYS_EAGER = false
CELERY_TASK_EAGER_PROPAGATES = false
CELERY_TASK_TIME_LIMIT = 300
CELERY_TASK_SOFT_TIME_LIMIT = 240
CELERY_WORKER_PREFETCH_MULTIPLIER = 1
CELERY_ACKS_LATE = true
CELERY_CPU_CONCURRENCY = 2 # DevOps baseline: 2..4 depending on CPU/RAM
CELERY_GPU_CONCURRENCY = 1 # DevOps baseline: 1 (safe), 2 for 24GB VRAM after validation

COMPARE_QUEUE_CPU = "compare-cpu"
COMPARE_QUEUE_GPU = "compare-gpu"
ENABLE_GPU_QUEUE = false
COMPARE_EXECUTION_DEVICE = "auto" # auto|cpu|gpu

# Worker metrics endpoint (for Prometheus scraping)
PROMETHEUS_WORKER_ENABLED = false
PROMETHEUS_WORKER_ADDR = "0.0.0.0"
PROMETHEUS_WORKER_PORT = 9101 # use unique port per worker service (e.g. CPU 9101, GPU 9102)
PROMETHEUS_MULTIPROC_DIR = "" # set for prefork concurrency >1, e.g. /tmp/pms-prom-cpu

# Optional API logging sink
LOG_API_ENABLED = false
LOG_API_URL = ""
LOG_API_LEVEL = "ERROR"
LOG_API_TIMEOUT_MS = 2000
LOG_API_TOKEN = ""
LOG_SERVICE_NAME = "perceptual-metrics-service"

# Optional HMAC request authentication for compare endpoints
HMAC_ENABLED = false
HMAC_SECRET = ""
HMAC_ALLOWED_SKEW_SEC = 300
HMAC_REQUIRE_NONCE = true
HMAC_NONCE_TTL_SEC = 300

# Optional runtime git metadata overrides
APP_GIT_BRANCH = ""
APP_GIT_TAG = ""
APP_GIT_LAST_COMMIT = ""
APP_GIT_COMMITTER = ""
APP_GIT_COMMIT_DATE = ""
