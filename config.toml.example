[env]
API_DEBUG = "1"
IMAGE_BASE_DIR = "."
LOG_LEVEL = "INFO"

# Distributed jobs (Celery + Redis)
JOB_STORE_BACKEND = "redis" # redis|memory
REDIS_URL = "redis://127.0.0.1:6379/0"
REDIS_PREFIX = "pms"
JOB_TTL_SEC = 86400
HEATMAP_TTL_SEC = 86400

CELERY_BROKER_URL = "redis://127.0.0.1:6379/0"
CELERY_RESULT_BACKEND = "redis://127.0.0.1:6379/0"
CELERY_TASK_ALWAYS_EAGER = false
CELERY_TASK_EAGER_PROPAGATES = false
CELERY_TASK_TIME_LIMIT = 300
CELERY_TASK_SOFT_TIME_LIMIT = 240
CELERY_WORKER_PREFETCH_MULTIPLIER = 1
CELERY_ACKS_LATE = true

COMPARE_QUEUE_CPU = "compare-cpu"
COMPARE_QUEUE_GPU = "compare-gpu"
ENABLE_GPU_QUEUE = false
COMPARE_EXECUTION_DEVICE = "auto" # auto|cpu|gpu

# Optional API logging sink
LOG_API_ENABLED = false
LOG_API_URL = ""
LOG_API_LEVEL = "ERROR"
LOG_API_TIMEOUT_MS = 2000
LOG_API_TOKEN = ""
LOG_SERVICE_NAME = "perceptual-metrics-service"

# Git metadata is now read directly from git CLI
