API_DEBUG=1
LOG_LEVEL=INFO
IMAGE_BASE_DIR=.

JOB_STORE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=pms
JOB_TTL_SEC=86400
HEATMAP_TTL_SEC=86400

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_ACKS_LATE=true

COMPARE_QUEUE_CPU=compare-cpu
COMPARE_QUEUE_GPU=compare-gpu
ENABLE_GPU_QUEUE=false
COMPARE_EXECUTION_DEVICE=auto

API_WORKERS=2
CELERY_CPU_CONCURRENCY=4
CELERY_GPU_CONCURRENCY=1
CELERY_LOG_LEVEL=INFO
